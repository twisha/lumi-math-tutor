# Required: get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_api_key_here

# Optional: change the Claude model (default is Haiku — fast and cheap)
# Options: claude-haiku-4-5-20251001 | claude-sonnet-4-6 | claude-opus-4-8
LUMI_MODEL=claude-haiku-4-5-20251001

# LangSmith tracing (optional) — get your key at https://smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_key_here
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=lumi-math-tutor
